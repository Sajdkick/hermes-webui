let _workspaceList = [];  // cached from /api/workspaces

function _positionProfileDropdown(){
  const dd=$('profileDropdown');
  const chip=$('profileChip');
  const footer=document.querySelector('.composer-footer');
  if(!dd||!chip||!footer) return;
  const chipRect=chip.getBoundingClientRect();
  const footerRect=footer.getBoundingClientRect();
  dd.style.visibility='hidden';
  dd.classList.add('open');
  const ddRect=dd.getBoundingClientRect();
  const margin=8;
  const maxLeft=window.innerWidth-ddRect.width-margin;
  const left=Math.max(margin,Math.min(maxLeft,chipRect.right-ddRect.width));
  const bottom=Math.max(footerRect.height-chipRect.top+margin,footerRect.height+margin);
  dd.style.left=`${left}px`;
  dd.style.bottom=`${bottom}px`;
  dd.style.visibility='';
}

// ── Profile panel + dropdown ──
let _profilesCache = null;
let _profileModelsCache = null;

function _profileIsActive(profile) {
  return !!(profile && profile.isActive);
}

function _profileIsDefault(profile) {
  return !!(profile && profile.isDefault);
}

function _profileGatewayRunning(profile) {
  return !!(profile && profile.gatewayRunning);
}

function _profileSkillCount(profile) {
  const raw = profile && profile.skillCount;
  const count = Number(raw);
  return Number.isFinite(count) ? count : 0;
}

function _profileCredentialsConfigured(profile) {
  return !!(profile && profile.credentialsConfigured);
}

async function _loadProfileModels() {
  if (_profileModelsCache) return _profileModelsCache;
  try {
    _profileModelsCache = await AgentBridge.profiles.modelCatalog();
  } catch (_e) {
    _profileModelsCache = { groups: [] };
  }
  return _profileModelsCache;
}

function _profileModelOptionsHtml(modelsData, selectedModel) {
  const groups = Array.isArray(modelsData && modelsData.groups) ? modelsData.groups : [];
  const normalizedSelected = String(selectedModel || '').trim();
  const rows = [];
  let found = false;
  for (const group of groups) {
    const options = [];
    for (const model of Array.isArray(group && group.models) ? group.models : []) {
      const modelId = String(model && model.id || '').trim();
      if (!modelId) continue;
      const label = (typeof _modelOptionDisplayLabel === 'function')
        ? _modelOptionDisplayLabel(model)
        : (model.label || modelId);
      if (modelId === normalizedSelected) found = true;
      options.push(`<option value="${esc(modelId)}" ${modelId === normalizedSelected ? 'selected' : ''}>${esc(label)}</option>`);
    }
    if (options.length) {
      rows.push(`<optgroup label="${esc(group.provider || 'Models')}">${options.join('')}</optgroup>`);
    }
  }
  if (normalizedSelected && !found) {
    rows.unshift(`<option value="${esc(normalizedSelected)}" selected>${esc(getModelLabel(normalizedSelected) || normalizedSelected)}</option>`);
  }
  if (!rows.length) {
    rows.push('<option value="">No models available</option>');
  }
  return rows.join('');
}

function _findProfileModelSelect(name) {
  return Array.from(document.querySelectorAll('[data-profile-model-name]')).find(
    (node) => node && node.dataset && node.dataset.profileModelName === name
  ) || null;
}

async function _syncActiveProfileModelUi(profiles) {
  const list = Array.isArray(profiles) ? profiles : [];
  const active = list.find((profile) => _profileIsActive(profile)) || null;
  if (!active || !active.model) return;
  localStorage.removeItem('hermes-webui-model');
  if (typeof populateModelDropdown === 'function') {
    await populateModelDropdown();
  }
  const sel = $('modelSelect');
  const resolved = _applyModelToDropdown(active.model, sel);
  const modelToUse = resolved || active.model;
  const visibleMessages = Array.isArray(S.messages) ? S.messages.filter(msg => msg && msg.role && msg.role !== 'tool') : [];
  if (S.session && visibleMessages.length === 0) {
    S.session.model = modelToUse;
  }
  if (typeof syncTopbar === 'function') syncTopbar();
}

async function loadProfilesPanel() {
  const panel = $('profilesPanel');
  if (!panel) return;
  try {
    const [data, modelsData] = await Promise.all([
      AgentBridge.profiles.list(),
      _loadProfileModels(),
    ]);
    _profilesCache = data;
    panel.innerHTML = '';
    if (!data.profiles || !data.profiles.length) {
      panel.innerHTML = `<div style="padding:16px;color:var(--muted);font-size:12px">${esc(t('profiles_no_profiles'))}</div>`;
      return;
    }
    const bulk = document.createElement('div');
    bulk.className = 'profile-card';
    bulk.innerHTML = `
      <div class="profile-card-header">
        <div style="min-width:0;flex:1">
          <div class="profile-card-name">Default model</div>
          <div class="profile-card-meta" style="padding-left:0">Update one profile directly or apply one model across every profile.</div>
        </div>
      </div>
      <div style="margin-top:10px;padding-left:12px;display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap">
        <label style="flex:1;min-width:180px">
          <div style="font-size:11px;color:var(--muted);margin-bottom:6px">Apply to all profiles</div>
          <select id="profileBulkModelSelect">${_profileModelOptionsHtml(modelsData, data.default_model || '')}</select>
        </label>
        <button class="ws-action-btn" onclick="applyDefaultModelToAllProfiles()">Apply to all</button>
      </div>`;
    panel.appendChild(bulk);
    for (const p of data.profiles) {
      const card = document.createElement('div');
      card.className = 'profile-card';
      const meta = [];
      if (p.model) meta.push(p.model.split('/').pop());
      if (p.provider) meta.push(p.provider);
      const skillCount = _profileSkillCount(p);
      if (skillCount) meta.push(t('profile_skill_count', skillCount));
      if (_profileCredentialsConfigured(p)) meta.push(t('profile_api_keys_configured'));
      const gwDot = _profileGatewayRunning(p)
        ? `<span class="profile-opt-badge running" title="${esc(t('profile_gateway_running'))}"></span>`
        : `<span class="profile-opt-badge stopped" title="${esc(t('profile_gateway_stopped'))}"></span>`;
      const isActive = p.name === data.active;
      const activeBadge = isActive ? `<span style="color:var(--link);font-size:10px;font-weight:600;margin-left:6px">${esc(t('profile_active'))}</span>` : '';
      const defaultBadge = _profileIsDefault(p) ? ` <span style="opacity:.5">${esc(t('profile_default_label'))}</span>` : '';
      card.innerHTML = `
        <div class="profile-card-header">
          <div style="min-width:0;flex:1">
            <div class="profile-card-name${isActive ? ' is-active' : ''}">${gwDot}${esc(p.name)}${defaultBadge}${activeBadge}</div>
            ${meta.length ? `<div class="profile-card-meta">${esc(meta.join(' \u00b7 '))}</div>` : `<div class="profile-card-meta">${esc(t('profile_no_configuration'))}</div>`}
          </div>
          <div class="profile-card-actions">
            ${!isActive ? `<button class="ws-action-btn" onclick="switchToProfile('${esc(p.name)}')" title="${esc(t('profile_switch_title'))}">${esc(t('profile_use'))}</button>` : ''}
            ${!_profileIsDefault(p) ? `<button class="ws-action-btn danger" onclick="deleteProfile('${esc(p.name)}')" title="${esc(t('profile_delete_title'))}">${li('x',12)}</button>` : ''}
          </div>
        </div>
        <div style="margin-top:10px;padding-left:12px;display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap">
          <label style="flex:1;min-width:180px">
            <div style="font-size:11px;color:var(--muted);margin-bottom:6px">Default model</div>
            <select data-profile-model-name="${esc(p.name)}">${_profileModelOptionsHtml(modelsData, p.model || '')}</select>
          </label>
          <button class="ws-action-btn" onclick="saveProfileModel('${esc(p.name)}')">Save</button>
        </div>`;
      panel.appendChild(card);
    }
  } catch (e) {
    panel.innerHTML = `<div style="color:var(--accent);font-size:12px;padding:12px">${esc(t('error_prefix'))}${esc(e.message)}</div>`;
  }
}

async function saveProfileModel(name) {
  const select = _findProfileModelSelect(name);
  const defaultModel = String(select && select.value || '').trim();
  if (!defaultModel) {
    showToast('Select a model first');
    return;
  }
  try {
    const data = await AgentBridge.profiles.update({ name, default_model: defaultModel });
    _profilesCache = { profiles: data.profiles || [], active: data.active || name };
    await loadProfilesPanel();
    await _syncActiveProfileModelUi(data.profiles || []);
    showToast(`Saved default model for ${name}`);
  } catch (e) {
    showToast('Failed to save profile model: ' + e.message);
  }
}

async function applyDefaultModelToAllProfiles() {
  const select = $('profileBulkModelSelect');
  const defaultModel = String(select && select.value || '').trim();
  if (!defaultModel) {
    showToast('Select a model first');
    return;
  }
  const ok = typeof showConfirmDialog === 'function'
    ? await showConfirmDialog({
        title: 'Apply default model to all profiles',
        message: 'This updates the saved default model for every profile.',
        confirmLabel: 'Apply',
        focusCancel: true,
      })
    : window.confirm('Apply this default model to all profiles?');
  if (!ok) return;
  try {
    const data = await AgentBridge.profiles.bulkDefaultModel({ model: defaultModel });
    _profilesCache = { profiles: data.profiles || [], active: data.active || S.activeProfile };
    await loadProfilesPanel();
    await _syncActiveProfileModelUi(data.profiles || []);
    const count = Array.isArray(data.updated) ? data.updated.length : 0;
    showToast(`Updated ${count} profile${count === 1 ? '' : 's'}`);
  } catch (e) {
    showToast('Failed to update profile models: ' + e.message);
  }
}

function renderProfileDropdown(data) {
  const dd = $('profileDropdown');
  if (!dd) return;
  dd.innerHTML = '';
  const profiles = data.profiles || [];
  const active = data.active || 'default';
  for (const p of profiles) {
    const opt = document.createElement('div');
    opt.className = 'profile-opt' + (p.name === active ? ' active' : '');
    const meta = [];
    if (p.model) meta.push(p.model.split('/').pop());
    const skillCount = _profileSkillCount(p);
    if (skillCount) meta.push(t('profile_skill_count', skillCount));
    const gwDot = `<span class="profile-opt-badge ${_profileGatewayRunning(p) ? 'running' : 'stopped'}"></span>`;
    const checkmark = p.name === active ? ' <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--link)" stroke-width="3" style="vertical-align:-1px"><polyline points="20 6 9 17 4 12"/></svg>' : '';
    const defaultBadge = _profileIsDefault(p) ? ` <span style="opacity:.5;font-weight:400">${esc(t('profile_default_label'))}</span>` : '';
    opt.innerHTML = `<div class="profile-opt-name">${gwDot}${esc(p.name)}${defaultBadge}${checkmark}</div>` +
      (meta.length ? `<div class="profile-opt-meta">${esc(meta.join(' \u00b7 '))}</div>` : '');
    opt.onclick = async () => {
      closeProfileDropdown();
      if (p.name === active) return;
      await switchToProfile(p.name);
    };
    dd.appendChild(opt);
  }
  // Divider + Manage link
  const div = document.createElement('div'); div.className = 'ws-divider'; dd.appendChild(div);
  const mgmt = document.createElement('div'); mgmt.className = 'profile-opt ws-manage';
  mgmt.innerHTML = `${li('settings',12)} ${esc(t('manage_profiles'))}`;
  mgmt.onclick = () => { closeProfileDropdown(); mobileSwitchPanel('profiles'); };
  dd.appendChild(mgmt);
}

