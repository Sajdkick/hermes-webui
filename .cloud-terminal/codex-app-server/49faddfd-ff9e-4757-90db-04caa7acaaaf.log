    def create_play_notification(self, payload: dict | None = None) -> dict[str, Any]:
        from api import notifications

        return notifications.create_play_notification(payload or {})

    def create_done_notification(self, session, stream_id: str, *, usage: dict | None = None) -> dict[str, Any]:
        from api import notifications

        return notifications.create_done_notification(session, stream_id, usage=usage)

    def _complete_session_run(self, session, *, status: str, summary: str) -> dict | None:
        session_id = str(getattr(session, "session_id", "") or "").strip()
        project_id = str(getattr(session, "ops_project_id", "") or "").strip()
        task_id = str(getattr(session, "ops_task_id", "") or "").strip()
        if not session_id:
            return None
        try:
            runs = _ops_sessions_call(
                ops_sessions.list_ops_runs,
                {
                    "sessionId": session_id,
                    "projectId": project_id,
                    "taskId": task_id,
                },
            ).get("runs", [])
            run = runs[0] if runs else None
            if not run or not run.get("id"):
                return None
            return _ops_sessions_call(
                ops_sessions.complete_ops_run,
                run["id"],
                {
                    "status": status,
                    "summary": summary,
                    "source": "streaming",
                    "metadata": {
                        "sessionId": session_id,
                        "projectId": project_id,
                        "taskId": task_id,
                    },
                },
            )
        except AgentBridgeError:
            logger.debug("Failed to finalize ops run for session %s", session_id, exc_info=True)
            return None

    def finalize_session_completion(self, session, stream_id: str | None = None, *, usage: dict | None = None) -> dict[str, Any]:
        session_id = str(getattr(session, "session_id", "") or "").strip()
        title = str(getattr(session, "title", "") or "Untitled").strip() or "Untitled"
        project_id = str(getattr(session, "ops_project_id", "") or "").strip()

        if project_id and session_id:
            try:
                from api.agent_bridge import play as agent_play

                play_info = agent_play.get_play_config_file_info(project_id)
            except Exception:
                play_info = {"configured": False}
                logger.debug("Failed to inspect Play config for project %s", project_id, exc_info=True)
            if play_info.get("configured"):
                try:
                    play_status = agent_play.start_play(
                        project_id,
                        {
                            "terminalTargetSessionId": session_id,
                            "sessionId": session_id,
                        },
                    )
                except Exception as exc:
                    message = str(exc) or "Play did not start."
                    self.create_play_notification(
                        {
                            "projectId": project_id,
                            "sessionId": session_id,
                            "sessionTitle": title,
                            "status": "failed",
                            "terminalTarget": {
                                "projectId": project_id,
                                "sessionId": session_id,
                            },
                            "sourceKey": f"play:failed:{project_id or session_id}:{stream_id or session_id}",
                            "playRequested": True,
                            "playFallbackError": message,
                            "message": "Play handoff failed. Open the project and repair Play with the captured error.",
                            "usage": usage or {},
                        }
                    )
                    self._complete_session_run(
                        session,
                        status="failed",
                        summary=f"Play did not start: {message}",
                    )
                    return {
                        "notification": "play-failed",
                        "playRequested": True,
                        "playStarted": False,
                        "playError": message,
                    }
                return {
                    "notification": "play-pending",
                    "playRequested": True,
                    "playStarted": True,
                    "playStatus": play_status,
                }

        self.create_done_notification(session, stream_id, usage=usage)
        self._complete_session_run(session, status="succeeded", summary=f"{title} finished.")
        return {
            "notification": "done",
            "playRequested": False,
            "playStarted": False,
        }

