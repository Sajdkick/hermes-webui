async function waitForManagedBackend(name, maxWaitMs = BACKEND_STARTUP_TIMEOUT_MS) {
  const config = appConfigs[name];
  const startedAt = Date.now();
  let readySince = 0;
  let lastState = getManagedAppProcessState(name);
  let lastPortReady = false;

  while (Date.now() - startedAt < maxWaitMs) {
    lastState = getManagedAppProcessState(name);
    if (!lastState.running) {
      return { ready: false, processExited: true, state: lastState, portReady: lastPortReady };
    }

    lastPortReady = await isBackendReady(config.port);
    if (lastPortReady) {
      if (!readySince) readySince = Date.now();
      if (Date.now() - readySince >= BACKEND_START_STABLE_MS) {
        return { ready: true, processExited: false, state: lastState, portReady: true };
      }
    } else {
      readySince = 0;
    }

    await delay(100);
  }

  return { ready: false, processExited: false, state: lastState, portReady: lastPortReady };
}

