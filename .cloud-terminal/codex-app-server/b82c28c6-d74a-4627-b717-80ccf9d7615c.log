def extract_const(source: str, name: str) -> str:
    prefix = f"const {name}="
    start = source.find(prefix)
    assert start >= 0, f"Could not find const {name}"
    end = source.find(";", start)
    assert end >= 0, f"Could not find end of const {name}"
    return source[start : end + 1]


def extract_function(source: str, name: str) -> str:
    prefix = f"function {name}("
    start = source.find(prefix)
    assert start >= 0, f"Could not find function {name}"
    brace = source.find("{", start)
    assert brace >= 0, f"Could not find function body for {name}"
    depth = 0
    for index in range(brace, len(source)):
        char = source[index]
        if char == "{":
            depth += 1
        elif char == "}":
            depth -= 1
            if depth == 0:
                return source[start : index + 1]
    raise AssertionError(f"Could not find end of function {name}")


def run_filter_helpers(script_body: str):
    source = OPS_PROJECT_DETAIL_JS.read_text(encoding="utf-8")
    constants = "\n".join(
        extract_const(source, name)
        for name in (
            "TASK_QA_STATUS_VALUES",
            "TASK_FILTER_STATUS_VALUES",
        )
    )
    functions = "\n".join(
        extract_function(source, name)
        for name in (
            "normalizeTaskQaStatus",
            "normalizeTaskFilterStatus",
            "normalizeTaskGradeFilter",
            "normalizeTaskTokenFilter",
            "buildTaskLookup",
            "taskDependencyBlocked",
            "taskStatusKey",
            "taskMarkerFlagText",
            "taskMatchesFilter",
            "summarizeTaskFilters",
        )
    )
    script = textwrap.dedent(
        f"""
        const ctx = {{}};
        {constants}
        {functions}
        {script_body}
        """
        """
    )
    completed = subprocess.run(
        ["node", "-e", script],
        check=True,
        capture_output=True,
        text=True,
    )
    return json.loads(completed.stdout)


