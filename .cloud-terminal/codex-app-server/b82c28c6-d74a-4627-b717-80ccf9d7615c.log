def _session_project_id(session: dict[str, Any]) -> str:
    return str(
        session.get("ops_project_id")
        or session.get("opsProjectId")
        or session.get("project_id")
        or session.get("projectId")
        or ""
    ).strip()


def _session_task_id(session: dict[str, Any]) -> str:
    return str(
        session.get("ops_task_id")
        or session.get("opsTaskId")
        or session.get("task_id")
        or session.get("taskId")
        or ""
    ).strip()


def _session_activity_ts(session: dict[str, Any]) -> float:
    values: list[float] = []
    for key in ("lastActivityAt", "lastOutputAt", "updated_at", "created_at"):
        value = session.get(key)
        try:
            values.append(float(value or 0))
        except (TypeError, ValueError):
            continue
    return max(values) if values else 0.0


def _latest_task_session(project_id: str, task_id: str, sessions: list[dict[str, Any]]) -> dict[str, Any] | None:
    latest = None
    for session in sessions:
        if not isinstance(session, dict) or session.get("archived"):
            continue
        if _session_project_id(session) != project_id or _session_task_id(session) != task_id:
            continue
        if latest is None or _session_activity_ts(session) > _session_activity_ts(latest):
            latest = session
    return latest


