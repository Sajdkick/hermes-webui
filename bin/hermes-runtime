  const payload = await apiRequest(
    context,
    'GET',
    `/inspect/guides/${encodeURIComponent(normalizedGuideId)}`
  );
  if (flags.json) {
    printJson(payload);
    return;
  }
  printInspectGuideRecording(payload);
}

