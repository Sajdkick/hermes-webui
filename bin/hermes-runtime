#!/usr/bin/env node

const fs = require('node:fs');
const path = require('node:path');

const DEFAULT_PLAY_WAIT_TIMEOUT_MS = 10 * 60 * 1000;

const GENERAL_HELP_TEXT = `hermes-runtime

Usage:
  hermes-runtime doctor [--json]
  hermes-runtime status [--json]
  hermes-runtime play status [--json]
  hermes-runtime play start [--wait] [--restart] [--timeout <duration>] [--json]
  hermes-runtime play stop [--json]
  hermes-runtime play logs [--limit <n>] [--json]
  hermes-runtime inspect url [--json]
  hermes-runtime inspect reset-state [--timeout <duration>] [--json]
  hermes-runtime inspect request-review [message] [--url <url>] [--timeout <duration>] [--json]
  hermes-runtime inspect request-image-review <image-path> [message] [--json]
  hermes-runtime inspect guide request [message] [--url <url>] [--timeout <duration>] [--json]
  hermes-runtime inspect guide list [--query <text>] [--limit <n>] [--json]
  hermes-runtime inspect guide show <guide-id> [--json]
  hermes-runtime inspect guide update <guide-id> (--content <text> | --content-file <path>) [--json]
  hermes-runtime inspect guide delete <guide-id> [--json]
  hermes-runtime inspect screenshot [--url <url>] [--session <id>] [--keep-session] [--selector <css-or-text>] [--nth <index>] [--width <px>] [--height <px>] [--delay <duration>] [--timeout <duration>] [--file-name <name>] [--out <path>] [--json]
  hermes-runtime inspect action [--url <url>] [--session <id>] [--keep-session] [--capture-screenshot] [--width <px>] [--height <px>] [--delay <duration>] [--timeout <duration>] [--file-name <name>] [--out <path>] [--gather <report-id>] [--compare <previous-or-bundle-path>] (--script <json> | --script-file <path>) [--json]
  hermes-runtime inspect run-script <path> [--url <url>] [--session <id>] [--keep-session] [--width <px>] [--height <px>] [--delay <duration>] [--timeout <duration>] [--gather <report-id>] [--compare <previous-or-bundle-path>] [--adapter <path>] [--json]
  hermes-runtime inspect scenario list [--json]
  hermes-runtime inspect scenario run <scenario-id> [--url <url>] [--session <id>] [--keep-session] [--width <px>] [--height <px>] [--delay <duration>] [--timeout <duration>] [--gather <report-id>] [--compare <previous-or-bundle-path>] [--adapter <path>] [--json]
  hermes-runtime inspect session close <session-id> [--json]
  hermes-runtime gather create [--title <text>] [--json]
  hermes-runtime gather show [report-id] [--json]

\`hermes-runtime doctor --json\` is the first command to run when Play/inspect notifications or runtime access look broken.
Durations accept ms, s, or m suffixes. Examples: 1500ms, 20s, 4m.
If Play status is \`queued\`, another project build is ahead of you in the global build queue.
Treat \`queued\` as in progress: keep waiting, re-check \`hermes-runtime play status\`, or use a longer \`hermes-runtime play start --wait --timeout <duration>\`.
If Play config enables inspect auth (for example \`inspect.auth.strategy=debug-login\` or \`AUTH_DEBUG_LOGIN=true\`),
\`hermes-runtime inspect screenshot\` primes a temporary authenticated browser session before capture.
\`hermes-runtime inspect action\` uses the same inspect browser to run scripted wait/click/drag/evaluate/assert/media/frame steps, including canvas-relative pointer input and inline video/canvas capture.
\`hermes-runtime inspect action\` selectors accept CSS and Playwright-style \`text=\` queries with normalized whitespace matching.
\`hermes-runtime inspect action --capture-screenshot\` captures the mutated page before that browser session is torn down.
\`hermes-runtime inspect screenshot --selector <query>\` scrolls a matched element into view before capturing just that region.
\`hermes-runtime inspect reset-state\` ensures Play is ready, resolves the active inspect/browser URLs, and runs the optional project-local \`inspect.reset\` hook for clearing seeded debug state.
\`hermes-runtime inspect request-image-review <image-path> "..."\` sends a saved screenshot or frame to the user in an inline image-review modal so they can answer without opening the live session.
\`hermes-runtime inspect request-review "..."\` is better when the user needs to inspect the live Play session, click around, or review motion instead of a single still image.
\`hermes-runtime inspect request-image-review\` is usually the fastest follow-up after \`inspect screenshot\` or \`inspect action --capture-screenshot\` when you want human confirmation of a visual change.
\`hermes-runtime inspect action --help\` prints the action schema plus valid JSON examples for common flows.
\`hermes-runtime inspect run-script\` executes a project-local Node automation script with helper methods that reuse the managed inspect session instead of launching a separate browser.
\`hermes-runtime inspect scenario list\` discovers project-local scenarios under \`.hermes/inspect-scenarios\`, \`.hermes/inspect/scenarios\`, and \`inspect-scenarios\`.
\`hermes-runtime inspect scenario run\` executes a named scenario with the same managed inspect helpers plus optional adapter loading, gather snapshots, and previous-run bundle comparison.
\`--keep-session\` returns a persistent inspect session id that later \`inspect action\` / \`inspect screenshot\` commands can reuse.
\`hermes-runtime inspect guide request\` asks the user to demonstrate a flow in Play and saves a reusable project-scoped guide recording.
\`hermes-runtime inspect guide list\`, \`hermes-runtime inspect guide show\`, and \`hermes-runtime inspect guide delete\` let the agent review and clean up project-scoped guide recordings.
\`hermes-runtime inspect guide update\` saves a clearer maintained guide next to the raw recording so future agents can follow written steps and pitfalls before consulting the event log.
`;

const INSPECT_SCREENSHOT_HELP_TEXT = `hermes-runtime inspect screenshot

Usage:
  hermes-runtime inspect screenshot [--url <url>] [--session <id>] [--keep-session] [--selector <css-or-text>] [--nth <index>] [--width <px>] [--height <px>] [--delay <duration>] [--timeout <duration>] [--file-name <name>] [--out <path>] [--json]

Behavior:
  Captures either the full page or a targeted element from the managed inspect browser.
  When \`--selector\` is set, hermes-runtime scrolls the matched element into view and captures only that region.
  Selectors accept CSS and Playwright-style \`text=\` queries with normalized whitespace matching.
  Use \`--session <id>\` to reuse an existing inspect session instead of launching a new browser.

Examples:
  hermes-runtime inspect screenshot --url /app/video-generation
  hermes-runtime inspect screenshot --url /app/video-generation --selector 'figure.preview'
  hermes-runtime inspect screenshot --session inspect-session-123 --selector 'text=Latest Generated Frame' --out latest-frame.png
  hermes-runtime inspect screenshot --url /app/scenarios --selector 'canvas' --nth 1 --file-name scenario-canvas
`;

const INSPECT_ACTION_HELP_TEXT = `hermes-runtime inspect action

Usage:
  hermes-runtime inspect action [--url <url>] [--session <id>] [--keep-session] [--capture-screenshot] [--width <px>] [--height <px>] [--delay <duration>] [--timeout <duration>] [--file-name <name>] [--out <path>] [--gather <report-id>] [--compare <previous-or-bundle-path>] (--script <json> | --script-file <path>) [--json]

Action schema:
  Each step must be a JSON object with a \`type\`.
  Common fields:
    - \`selector\`: CSS selector or \`text=...\` query
    - \`nth\`: zero-based match index
    - \`delayMs\`: extra delay after a step
    - \`timeoutMs\`: polling timeout for wait steps

Supported action types:
  - \`wait\`
  - \`waitForSelector\`
  - \`waitForSelectorVisible\`
  - \`scrollIntoView\`
  - \`waitForMediaReady\`
  - \`setMediaTime\`
  - \`click\`
  - \`drag\`
  - \`evaluate\`
  - \`assert\`
  - \`captureElementScreenshot\`
  - \`captureVideoFrame\`
  - \`captureCanvasFrame\`
  - \`captureFrames\`

Compact schema examples:
  1. Wait for visible UI, scroll to it, then capture the element:
     [
       { "type": "waitForSelectorVisible", "selector": "figure.preview" },
       { "type": "scrollIntoView", "selector": "figure.preview" },
       { "type": "captureElementScreenshot", "selector": "figure.preview", "label": "latest-frame" }
     ]

  2. Click a button and assert app state:
     [
       { "type": "click", "selector": "text=Generate Video" },
       { "type": "assert", "expression": "window.__videoStarted === true", "message": "video generation should start" }
     ]

  3. Capture a canvas-relative drag workflow:
     [
       { "type": "waitForSelector", "selector": "canvas" },
       { "type": "drag", "selector": "canvas", "fromX": 20, "fromY": 20, "toX": 180, "toY": 120 }
     ]

  4. Capture a specific video frame:
     [
       { "type": "waitForMediaReady", "selector": "video.preview", "readyState": 4 },
       { "type": "setMediaTime", "selector": "video.preview", "timeSeconds": 2.5 },
       { "type": "captureVideoFrame", "selector": "video.preview", "label": "poster" }
     ]

  5. Capture progress snapshots over time:
     [
       { "type": "captureFrames", "selector": "video.preview", "times": [1, 2, 3], "label": "sequence" }
     ]

Notes:
  \`waitForSelector\` defaults to visible state. Use \`waitForSelectorVisible\` when you want the intent to be explicit in logs and scripts.
  \`evaluate\` and \`assert\` require \`expression\`, not \`value\` or \`code\`.
  \`--gather latest\` snapshots the latest gather report into the action bundle after the run finishes.
  \`--compare previous\` compares the emitted inspect bundle against the last bundle for the same action script.
  Use \`--keep-session\` to keep the browser open and reuse it with later \`inspect action\` or \`inspect screenshot\` commands.
  If you need human eyes on the final still image, follow up with \`hermes-runtime inspect request-image-review <saved-image-path> "What should the user verify?"\`.
`;

