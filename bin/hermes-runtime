async function handleGatherCreate(context, flags) {
  const payload = await apiRequest(context, 'POST', '/gather/reports', {
    title: flags.title || '',
  });
  if (flags.json) {
    printJson(payload);
    return;
  }
  process.stdout.write('Gather report created.\n');
  printGatherReportSummary(payload?.report || null);
  if (payload?.ingest?.path) {
    process.stdout.write(`Ingest path: ${payload.ingest.path}\n`);
  }
  if (payload?.ingest?.url) {
    process.stdout.write(`Ingest URL: ${payload.ingest.url}\n`);
  }
  if (payload?.ingest?.tokenHeader) {
    process.stdout.write(`Token header: ${payload.ingest.tokenHeader}\n`);
  }
  if (payload?.ingest?.token) {
    process.stdout.write(`Token: ${payload.ingest.token}\n`);
  }
}

async function handleGatherShow(context, flags, reportId) {
  const route = reportId
    ? `/gather/reports/${encodeURIComponent(reportId)}`
    : '/gather/reports/latest';
  const payload = await apiRequest(context, 'GET', route);
  if (flags.json) {
    printJson(payload);
    return;
  }
  printGatherReportSummary(payload?.report || null, payload?.events || []);
}

async function main() {
  const { flags, positionals } = parseArgs(process.argv.slice(2));
  if (flags.help || positionals.length === 0) {
    process.stdout.write(getHelpText(positionals));
    return;
  }

  const [command, subcommand, ...rest] = positionals;
  if (command === 'doctor') {
    handleDoctor(flags);
    return;
  }

  const diagnostics = buildRuntimeContextDiagnostics();
  if (!diagnostics.ok) {
    renderMissingRuntimeContext(diagnostics, flags);
    process.exit(1);
  }
  const context = runtimeContextFromDiagnostics(diagnostics);
  try {
    if (command === 'status') {
      await handleStatus(context, flags);
      return;
    }

    if (command === 'play' && subcommand === 'status') {
      await handlePlayStatus(context, flags);
      return;
    }
    if (command === 'play' && subcommand === 'start') {
      await handlePlayStart(context, flags);
      return;
    }
    if (command === 'play' && subcommand === 'stop') {
      await handlePlayStop(context, flags);
      return;
    }
    if (command === 'play' && subcommand === 'logs') {
      await handlePlayLogs(context, flags);
      return;
    }

    if (command === 'inspect' && subcommand === 'url') {
      await handleInspectUrl(context, flags);
      return;
    }
    if (command === 'inspect' && subcommand === 'reset-state') {
      await handleInspectResetState(context, flags);
      return;
    }
    if (command === 'inspect' && subcommand === 'request-review') {
      await handleInspectRequestReview(context, flags, rest);
      return;
    }
    if (command === 'inspect' && subcommand === 'request-image-review') {
      const [imagePath, ...messageParts] = rest;
      await handleInspectImageReview(context, imagePath || '', flags, messageParts);
      return;
    }
    if (command === 'inspect' && subcommand === 'guide' && rest[0] === 'request') {
      await handleInspectGuideRequest(context, flags, rest.slice(1));
      return;
    }
    if (command === 'inspect' && subcommand === 'guide' && rest[0] === 'list') {
      await handleInspectGuideList(context, flags);
      return;
    }
    if (command === 'inspect' && subcommand === 'guide' && rest[0] === 'show') {
      await handleInspectGuideShow(context, flags, rest[1] || '');
      return;
    }
    if (command === 'inspect' && subcommand === 'guide' && rest[0] === 'update') {
      await handleInspectGuideUpdate(context, flags, rest[1] || '');
      return;
    }
    if (command === 'inspect' && subcommand === 'guide' && rest[0] === 'delete') {
      await handleInspectGuideDelete(context, flags, rest[1] || '');
      return;
    }
    if (command === 'inspect' && subcommand === 'screenshot') {
      await handleInspectScreenshot(context, flags);
      return;
    }
    if (command === 'inspect' && subcommand === 'action') {
      await handleInspectAction(context, flags);
      return;
    }
    if (command === 'inspect' && subcommand === 'run-script') {
      await handleInspectRunScript(context, flags, rest[0] || '');
      return;
    }
    if (command === 'inspect' && subcommand === 'scenario' && rest[0] === 'list') {
      await handleInspectScenarioList(context, flags);
      return;
    }
    if (command === 'inspect' && subcommand === 'scenario' && rest[0] === 'run') {
      await handleInspectScenarioRun(context, flags, rest[1] || '');
      return;
    }
    if (command === 'inspect' && subcommand === 'session' && rest[0] === 'close') {
      const inspectSessionId = rest[1] || '';
      if (!inspectSessionId) {
        fail('inspect session close requires a session id.');
      }
      await handleInspectSessionClose(context, inspectSessionId, flags);
      return;
    }

    if (command === 'gather' && subcommand === 'create') {
      await handleGatherCreate(context, flags);
      return;
    }
    if (command === 'gather' && subcommand === 'show') {
      await handleGatherShow(context, flags, rest[0] || '');
      return;
    }

    fail(`Unknown command: ${positionals.join(' ')}`);
  } catch (error) {
    if (error?.runtimeCliFailure) {
      renderRuntimeRequestFailure(error.runtimeCliFailure, { json: flags.json });
      process.exit(1);
    }
    throw error;
  }
}

if (require.main === module) {
  main().catch((error) => {
    fail(error?.message || String(error));
  });
}

