}

async function handleInspectSessionClose(context, inspectSessionId, flags) {
  const payload = await apiRequest(
    context,
    'DELETE',
    `/inspect/sessions/${encodeURIComponent(inspectSessionId)}`,
    null
  );
  if (flags.json) {
    printJson(payload);
    return;
  }
  process.stdout.write('Inspect session closed.\n');
  printInspectSessionSummary(payload);
}

async function handleInspectGuideList(context, flags) {
  const searchParams = new URLSearchParams();
  if (flags?.query) {
    searchParams.set('query', String(flags.query));
  }
  if (flags?.limit != null) {
    searchParams.set('limit', String(parseInteger(flags.limit, '--limit')));
  }
  const route = searchParams.size > 0
    ? `/inspect/guides?${searchParams.toString()}`
    : '/inspect/guides';
  const payload = await apiRequest(context, 'GET', route);
  if (flags.json) {
    printJson(payload);
    return;
  }
  printInspectGuideList(payload?.guides || []);
}

